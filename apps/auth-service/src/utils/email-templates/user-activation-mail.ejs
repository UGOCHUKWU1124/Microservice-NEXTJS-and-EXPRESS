    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta http-equiv="X-UA-Compatible" content="ie=edge" />
        <title>ESHOP ONLINE Account Verification</title>
        <style>
        /* Reset styles for email clients */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
            Helvetica, Arial, sans-serif;
            line-height: 1.7;
            background-color: #f8f9fd;
            color: #2d3748;
            margin: 0;
            padding: 0;
        }

        .wrapper {
            background-color: #f8f9fd;
            padding: 30px 0;
            width: 100%;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 16px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
            overflow: hidden;
        }

        .header {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            padding: 40px 0;
            text-align: center;
        }

        .logo {
            font-size: 32px;
            color: #ffffff;
            font-weight: 800;
            text-decoration: none;
            letter-spacing: -1px;
            text-transform: uppercase;
        }

        .content {
            padding: 48px 40px;
            text-align: left;
        }

        h1 {
            color: #1a202c;
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 24px;
            text-align: center;
        }

        .greeting {
            font-size: 18px;
            margin-bottom: 24px;
            color: #4a5568;
        }

        p {
            color: #4a5568;
            font-size: 16px;
            margin-bottom: 20px;
        }

        .otp-container {
            background: #f7fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 32px;
            margin: 32px 0;
            text-align: center;
        }

        .otp-code {
            font-family: "Courier New", Courier, monospace;
            font-size: 36px;
            font-weight: 700;
            letter-spacing: 8px;
            color: #4f46e5;
            background: #ffffff;
            padding: 16px 24px;
            border-radius: 8px;
            border: 2px dashed #e2e8f0;
            display: inline-block;
        }

        .expiry-notice {
            background-color: #fff5f5;
            border-left: 4px solid #fc8181;
            padding: 16px 24px;
            margin: 24px 0;
            border-radius: 8px;
        }

        .warning-icon {
            color: #e53e3e;
            margin-right: 8px;
        }

        .highlight {
            color: #4f46e5;
            font-weight: 600;
        }

        .divider {
            height: 1px;
            background-color: #e2e8f0;
            margin: 32px 0;
        }

        .footer {
            background-color: #f8fafc;
            padding: 32px 40px;
            text-align: center;
        }

        .footer p {
            color: #718096;
            font-size: 14px;
            margin: 8px 0;
        }

        .social-links {
            margin-top: 24px;
        }

        .social-links a {
            color: #4f46e5;
            text-decoration: none;
            margin: 0 8px;
        }

        @media only screen and (max-width: 600px) {
            .content {
            padding: 32px 24px;
            }

            .otp-container {
            padding: 24px 16px;
            }

            .otp-code {
            font-size: 32px;
            letter-spacing: 6px;
            }
        }
        </style>
    </head>
    <body>
        <div class="wrapper">
        <div class="container">
            <div class="header">
            <div class="logo">ESHOP ONLINE</div>
            </div>
            <div class="content">
            <h1>Verify Your Email Address</h1>
            <p class="greeting">Hello <%= name %>,</p>
            <p>
                Welcome to UGO's ESHOP ONLINE! We're excited to have you on board.
                To ensure the security of your account, please verify your email
                address using the verification code below:
            </p>

            <div class="otp-container">
                <div class="otp-code"><%= otp %></div>
                <p style="margin-top: 16px; font-size: 14px; color: #718096">
                Please enter this code in the verification page
                </p>
            </div>

            <div class="expiry-notice">
                <span class="warning-icon">⚠️</span>
                This verification code will expire in
                <span class="highlight">5 minutes</span> for security purposes.
            </div>

            <p>
                If you did not create an account with UGO's ESHOP ONLINE, please
                disregard this email or contact our support team if you believe this
                was a mistake.
            </p>

            <div class="divider"></div>

            <p style="font-size: 14px; color: #718096">
                Need help? Contact our support team at
                <a
                href="mailto:ugoeshoponline@gmail.com"
                style="color: #4f46e5; text-decoration: none"
                >ugoeshoponline@gmail.com</a
                >
            </p>
            </div>
            <div class="footer">
            <p>
                This is an automated message. Please do not reply to this email.
            </p>
            <p>
                &copy; <%= new Date().getFullYear() %> UGO's ESHOP ONLINE. All
                rights reserved.
            </p>
            <div class="social-links">
                <a href="#">Twitter</a> • <a href="#">Facebook</a> •
                <a href="#">Instagram</a>
            </div>
            </div>
        </div>
        </div>
    </body>
    </html>
